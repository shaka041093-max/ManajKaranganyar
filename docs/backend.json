
{
  "entities": {
    "Kegiatan": {
      "title": "Kegiatan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" }
      }
    },
    "PhysicalActivity": {
      "title": "PhysicalActivity",
      "description": "Data kegiatan/proyek fisik untuk otomatisasi dokumen.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "namaKegiatan": { "type": "string" },
        "tahunAnggaran": { "type": "string" },
        "lokasi": { "type": "string" },
        "volume": { "type": "string" },
        "sumberDana": { "type": "string" },
        "anggaran": { "type": "number" },
        "pelaksanaKegiatan": { "type": "string" },
        "penyedia": { "type": "string" },
        "tanggalKegiatan": { "type": "string" },
        "namaKepalaDesa": { "type": "string" },
        "namaTpk": { "type": "string" },
        "namaBendahara": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["namaKegiatan", "tahunAnggaran", "anggaran"]
    },
    "BukuAgenda": {
      "title": "BukuAgenda",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "kategori": { "type": "string", "enum": ["surat_keluar", "surat_masuk", "perdes", "perkades", "sk", "sppd", "surat_tugas_sppd"] },
        "nomor": { "type": "string" },
        "perihal": { "type": "string" },
        "tanggal": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles and settings."
    },
    "/buku_agenda/{docId}": {
      "schema": { "$ref": "#/backend/entities/BukuAgenda" },
      "description": "Log of official document numbers."
    },
    "/naskah_dinas/{docId}": {
      "schema": "object",
      "description": "Official village documents."
    },
    "/physical_activities/{docId}": {
      "schema": { "$ref": "#/backend/entities/PhysicalActivity" },
      "description": "Activities for physical document automation."
    }
  }
}
